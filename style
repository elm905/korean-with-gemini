:root {
  color-scheme: light;
  --ink: #182026;
  --muted: #5a6670;
  --line: #d9e0e6;
  --panel: #ffffff;
  --soft: #f5f7f9;
  --accent: #176b5b;
  --accent-strong: #0f5145;
  --warn: #8a5b00;
  --warn-bg: #fff7e6;
  --verb: #1f6fb2;
  --adj: #9b4a79;
  --shadow: 0 16px 40px rgba(31, 48, 61, 0.12);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  background: linear-gradient(180deg, #eef4f5 0%, #f8faf8 44%, #ffffff 100%);
  color: var(--ink);
  font-family:
    "Pretendard",
    "Noto Sans KR",
    "Apple SD Gothic Neo",
    system-ui,
    sans-serif;
  line-height: 1.55;
}

button,
input {
  font: inherit;
}

.app-shell {
  width: min(1120px, calc(100% - 32px));
  margin: 0 auto;
  padding: 36px 0 56px;
}

.intro,
.input-panel,
.result-panel,
.reference-panel {
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid var(--line);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.intro {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 24px;
  padding: 34px;
}

.eyebrow {
  margin: 0 0 8px;
  color: var(--accent);
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0;
}

h1, h2, h3, p {
  margin-top: 0;
}

h1 {
  margin-bottom: 12px;
  font-size: clamp(2rem, 5vw, 3rem);
  line-height: 1.1;
}

h2 {
  margin-bottom: 18px;
  font-size: 1.35rem;
}

h3 {
  margin-bottom: 10px;
  font-size: 1rem;
}

.intro-copy {
  max-width: 620px;
  margin-bottom: 0;
  color: var(--muted);
  font-size: 1.05rem;
}

.quick-examples {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-end;
}

.input-panel,
.result-panel,
.reference-panel {
  margin-top: 18px;
  padding: 26px;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr; /* 1열로 변경 */
  gap: 14px;
}

label span {
  display: block;
  margin-bottom: 7px;
  font-weight: 800;
}

input {
  width: 100%;
  min-height: 48px;
  border: 1px solid #cbd5dc;
  border-radius: 6px;
  padding: 0 14px;
  background: #fff;
  color: var(--ink);
}

input:focus {
  border-color: var(--accent);
  outline: 3px solid rgba(23, 107, 91, 0.14);
}

.input-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

button {
  min-height: 42px;
  border: 0;
  border-radius: 6px;
  padding: 0 16px;
  cursor: pointer;
  font-weight: 800;
}

.primary-button {
  background: var(--accent);
  color: #fff;
}

.primary-button:hover {
  background: var(--accent-strong);
}

.secondary-button,
.ghost-button {
  border: 1px solid var(--line);
  background: #fff;
  color: var(--ink);
}

.secondary-button:hover,
.ghost-button:hover {
  border-color: var(--accent);
  color: var(--accent-strong);
}

.section-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16px;
}

.result-panel {
  border-top: 5px solid var(--accent);
}

.result-badge {
  display: inline-flex;
  align-items: center;
  min-height: 32px;
  border-radius: 999px;
  padding: 0 12px;
  background: #e8f4f1;
  color: var(--accent-strong);
  font-weight: 900;
}

.result-badge.verb {
  background: #e8f1fb;
  color: var(--verb);
}

.result-badge.adjective {
  background: #f8ebf3;
  color: var(--adj);
}

.result-badge.hold {
  background: var(--warn-bg);
  color: var(--warn);
}

.result-panel h2 {
  margin-top: 12px;
  margin-bottom: 8px;
}

.result-summary {
  color: var(--muted);
}

.result-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
  gap: 16px;
  margin-top: 18px;
}

.result-grid article,
.notice-box,
.reference-grid article {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 18px;
  background: #fff;
}

ol {
  margin: 0;
  padding-left: 20px;
}

li + li {
  margin-top: 8px;
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.94rem;
}

th, td {
  border-bottom: 1px solid var(--line);
  padding: 10px 8px;
  text-align: left;
  vertical-align: top;
}

th {
  color: var(--muted);
  font-size: 0.82rem;
}

.notice-box {
  margin-top: 16px;
  background: var(--warn-bg);
  color: #5b3e06;
}

.reference-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.reference-grid p {
  margin-bottom: 0;
  color: var(--muted);
}

.hidden {
  display: none;
}

@media (max-width: 820px) {
  .intro,
  .section-heading {
    display: block;
  }

  .quick-examples {
    justify-content: flex-start;
    margin-top: 20px;
  }

  .result-grid,
  .reference-grid {
    grid-template-columns: 1fr;
  }

  .intro,
  .input-panel,
  .result-panel,
  .reference-panel {
    padding: 22px;
  }
}